<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd" >

<suite name="QA Automation Suite" parallel="methods" thread-count="2">

    <listeners>
        <listener class-name="com.techbytes.qa.listeners.TestListener"/>
    </listeners>

    <test name="Herokuapp Tests">
        <groups>
            <run>
                <include name="smoke"/>
                <include name="regression"/>
            </run>
        </groups>

        <packages>
            <package name="com.techbytes.qa"/>
        </packages>
<!--        <classes>
            <class name="com.techbytes.qa.LoginTest"/>
            <class name="com.techbytes.qa.CheckBoxTest"/>
            <class name="com.techbytes.qa.DropdownTest"/>
        </classes>-->
    </test>

</suite>
