<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="QA-Automation-Suite" verbose="10" parallel="methods" thread-count="2">

    <listeners>
        <listener class-name="com.techbytes.qa.listeners.TestListener"/>
    </listeners>

    <test name="Web Tests">
        <groups>
            <run>
                <include name="smoke"/>
                <include name="regression"/>
            </run>
        </groups>

        <packages>
            <package name="com.techbytes.qa.tests"/>
        </packages>
<!--        <classes>
            <class name="com.techbytes.qa.tests.LoginTest"/>
            <class name="com.techbytes.qa.tests.ABTestingTest"/>
            <class name="com.techbytes.qa.tests.BasicAuthTest"/>
        </classes>-->
    </test>

</suite>